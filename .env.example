# API Platform Environment Configuration

# Database
DATABASE_URL=./data/platform.db   # SQLite file path (default). Change to a different path as needed.
# In production, set DATABASE_URL explicitly to a durable path/volume.
# ALLOW_DEFAULT_SQLITE_IN_PRODUCTION=false

# Server Configuration
NODE_ENV=development
PORT=3000
HTTPS_PORT=443
API_URL=http://localhost:3000
APP_PROFILE=core
# FULL_PROFILE_STRICT=false
# ENABLE_DEMO_ROUTES=false
# ENABLE_BOOTSTRAP_SEEDING=false
# STRICT_STARTUP_VALIDATION=false
# SHUTDOWN_TIMEOUT_MS=10000
# REFRESH_TOKEN_CLEANUP_INTERVAL_MS=3600000
# REFRESH_TOKEN_MAX_ACTIVE_SESSIONS=5
# SERVER_REQUEST_TIMEOUT_MS=30000
# SERVER_HEADERS_TIMEOUT_MS=35000
# SERVER_KEEP_ALIVE_TIMEOUT_MS=5000
# LOGIN_MAX_ATTEMPTS=5
# LOGIN_ATTEMPT_WINDOW_MS=900000
# LOGIN_LOCKOUT_DURATION_MS=900000
# DOCS_BASE_URL=https://docs.your-company.com
# API_MIGRATION_GUIDE_URL=https://docs.your-company.com/migration/2025-01-29
# BOOTSTRAP_ADMIN_EMAIL=admin@example.com
# BOOTSTRAP_ADMIN_PASSWORD=change-me
# BOOTSTRAP_ADMIN_NAME=Admin User
# BOOTSTRAP_AGENT_NAME=test-agent

# ──────────────────────────────────────────────────────────────
# Security Configuration
# ──────────────────────────────────────────────────────────────

# JWT Authentication
# Generate with: openssl rand -base64 32
# ⚠️ CRITICAL: MUST be set in production!
JWT_SECRET=change-me-in-production-use-openssl-rand-base64-32
JWT_EXPIRATION=1h
JWT_REFRESH_EXPIRATION=7d

# CORS - Allowed Origins (comma-separated)
# Development: Defaults to localhost if not set
# Production: MUST be explicitly configured
# Example: https://app.example.com,https://dashboard.example.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ──────────────────────────────────────────────────────────────
# HTTPS/TLS Configuration
# ──────────────────────────────────────────────────────────────

# Development: Generate self-signed certificates
# npm run generate:certs
# SSL_KEY_PATH=./certs/localhost-key.pem
# SSL_CERT_PATH=./certs/localhost-cert.pem

# Production: Use Let's Encrypt or commercial CA
# SSL_KEY_PATH=/etc/letsencrypt/live/yourdomain.com/privkey.pem
# SSL_CERT_PATH=/etc/letsencrypt/live/yourdomain.com/fullchain.pem
# SSL_CA_PATH=/etc/letsencrypt/live/yourdomain.com/chain.pem

# Disable TLS (not recommended for production)
# DISABLE_TLS=false
# ENFORCE_HTTPS=true
# TRUST_PROXY=true
# SECURITY_HSTS_ENABLED=true
# SECURITY_HSTS_MAX_AGE_SECONDS=31536000
# SECURITY_CSP_UPGRADE_INSECURE_REQUESTS=true

# ──────────────────────────────────────────────────────────────
# Secrets Management
# ──────────────────────────────────────────────────────────────

# Provider Selection (vault, aws, azure, env)
# SECRETS_PROVIDER=env

# HashiCorp Vault Configuration
# VAULT_ADDR=http://localhost:8200
# VAULT_TOKEN=your-vault-token
# VAULT_NAMESPACE=admin
# VAULT_MOUNT_PATH=secret

# AWS Secrets Manager Configuration
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# Azure Key Vault Configuration
# AZURE_KEY_VAULT_NAME=your-vault-name
# AZURE_KEY_VAULT_URL=https://your-vault.vault.azure.net
# AZURE_TENANT_ID=your-tenant-id
# AZURE_CLIENT_ID=your-client-id
# AZURE_CLIENT_SECRET=your-client-secret

# ──────────────────────────────────────────────────────────────
# Redis Configuration (Distributed Rate Limiting)
# ──────────────────────────────────────────────────────────────

# Redis Connection
# Development: Local Redis (default: localhost:6379)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# Production: Managed Redis (AWS ElastiCache, Azure Cache, etc.)
# REDIS_HOST=your-redis-instance.cache.amazonaws.com
# REDIS_PORT=6379
# REDIS_PASSWORD=your-redis-password
# REDIS_DB=0
# REDIS_TLS=true

# Disable Redis (use in-memory rate limiting)
# DISABLE_REDIS=false

# ──────────────────────────────────────────────────────────────
# Alert Delivery (optional)
# ──────────────────────────────────────────────────────────────

# Slack incoming webhook URL for alert notifications
# SLACK_WEBHOOK_URL=

# PagerDuty Events API v2 routing key
# PAGERDUTY_ROUTING_KEY=

# Generic webhook URL for alert delivery
# ALERT_WEBHOOK_URL=

# ──────────────────────────────────────────────────────────────
# Gateway Configuration (Optional)
# ──────────────────────────────────────────────────────────────

# Gateway Configuration (Optional)
# Set GATEWAY_PROVIDER to enable gateway integration
# Supported: kong, apigee, aws, azure, none (default)
# For multi-cloud, use comma-separated list: GATEWAY_PROVIDERS=kong,aws,azure
GATEWAY_PROVIDER=none
GATEWAY_ADMIN_URL=http://localhost:8001
GATEWAY_API_KEY=
GATEWAY_AUTO_SYNC=false
GATEWAY_SERVICE_NAME=api-platform

# Multi-Cloud Gateway (sync to multiple providers simultaneously)
# GATEWAY_PROVIDERS=kong,aws,azure,apigee

# OpenAPI Spec Path (Optional)
# OPENAPI_SPEC_PATH=./specs/openapi/platform-api.yaml

# ──────────────────────────────────────────────────────────────
# Single Gateway Examples
# ──────────────────────────────────────────────────────────────

# Kong Gateway Example:
# GATEWAY_PROVIDER=kong
# GATEWAY_ADMIN_URL=http://localhost:8001
# GATEWAY_AUTO_SYNC=true

# Apigee Gateway Example:
# GATEWAY_PROVIDER=apigee
# GATEWAY_ADMIN_URL=https://api.enterprise.apigee.com
# GATEWAY_API_KEY=your-access-token
# APIGEE_ORGANIZATION=your-org
# APIGEE_ENVIRONMENT=test
# APIGEE_USERNAME=your-email@example.com
# APIGEE_PASSWORD=your-password

# AWS API Gateway Example:
# GATEWAY_PROVIDER=aws
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# AWS_API_TYPE=HTTP  # or REST
# AWS_STAGE_NAME=$default

# Azure API Management Example:
# GATEWAY_PROVIDER=azure
# GATEWAY_API_KEY=your-bearer-token
# AZURE_SUBSCRIPTION_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# AZURE_RESOURCE_GROUP=my-resource-group
# AZURE_APIM_SERVICE_NAME=my-apim-service
# AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# AZURE_CLIENT_SECRET=your-client-secret

# ──────────────────────────────────────────────────────────────
# Multi-Cloud Gateway Example
# ──────────────────────────────────────────────────────────────
# Sync OpenAPI spec to all providers simultaneously:
#
# GATEWAY_PROVIDERS=kong,aws,azure
# GATEWAY_AUTO_SYNC=true
#
# # Kong configuration
# GATEWAY_KONG_ADMIN_URL=http://localhost:8001
#
# # AWS configuration
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret
# AWS_API_TYPE=HTTP
#
# # Azure configuration
# GATEWAY_AZURE_ADMIN_URL=https://management.azure.com
# AZURE_SUBSCRIPTION_ID=your-subscription-id
# AZURE_RESOURCE_GROUP=your-resource-group
# AZURE_APIM_SERVICE_NAME=your-apim-service
# GATEWAY_AZURE_API_KEY=your-bearer-token
