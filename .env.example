# API Platform Environment Configuration

# Server Configuration
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000

# Gateway Configuration (Optional)
# Set GATEWAY_PROVIDER to enable gateway integration
# Supported: kong, apigee, none (default)
GATEWAY_PROVIDER=none
GATEWAY_ADMIN_URL=http://localhost:8001
GATEWAY_API_KEY=
GATEWAY_AUTO_SYNC=false
GATEWAY_SERVICE_NAME=api-platform

# OpenAPI Spec Path (Optional)
# OPENAPI_SPEC_PATH=./specs/openapi/platform-api.yaml

# Kong Gateway Example:
# GATEWAY_PROVIDER=kong
# GATEWAY_ADMIN_URL=http://localhost:8001
# GATEWAY_AUTO_SYNC=true

# Apigee Gateway Example:
# GATEWAY_PROVIDER=apigee
# GATEWAY_ADMIN_URL=https://api.enterprise.apigee.com
# GATEWAY_API_KEY=your-access-token
# APIGEE_ORGANIZATION=your-org
# APIGEE_ENVIRONMENT=test
# APIGEE_USERNAME=your-email@example.com
# APIGEE_PASSWORD=your-password
