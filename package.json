{
  "name": "human-agent-api-platform",
  "version": "0.1.0",
  "description": "Agent-ready API toolkit (errors, dry-run, AX metrics) plus a reference platform for human and AI-agent clients",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/agent-errors",
    "packages/agent-dry-run",
    "packages/agent-metrics",
    "apps/reference"
  ],
  "scripts": {
    "build:packages": "npm run build -w packages/agent-errors -w packages/agent-dry-run -w packages/agent-metrics",
    "build": "npm run build:packages && npm run build -w apps/reference",
    "dev": "npm run dev -w apps/reference",
    "start": "npm run start -w apps/reference",
    "lint": "eslint packages apps --ext .ts",
    "lint:fix": "eslint packages apps --ext .ts --fix",
    "lint:api": "spectral lint apps/reference/specs/**/*.yaml --ruleset apps/reference/.spectral.yaml",
    "test": "vitest",
    "test:targeted": "vitest run apps/reference/src/auth/login-attempt-guard.test.ts apps/reference/src/auth/refresh-token-store.test.ts apps/reference/src/monitoring/startup-posture.test.ts apps/reference/src/middleware/https-enforcement.test.ts",
    "smoke:startup": "bash ./apps/reference/scripts/smoke-startup-validation.sh",
    "preflight:prod-env": "bash ./apps/reference/scripts/preflight-production-env.sh",
    "security:audit": "npm audit --omit=dev --audit-level=high",
    "test:coverage": "vitest --coverage",
    "type-check": "tsc --noEmit",
    "generate:tools": "npm run generate:tools -w apps/reference",
    "db:studio": "npm run db:studio -w apps/reference"
  },
  "keywords": [
    "api",
    "openapi",
    "ai-agents",
    "llm",
    "developer-experience"
  ],
  "author": "Sumeet Tandon",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/standonai/human-agent-api-platform.git"
  },
  "homepage": "https://github.com/standonai/human-agent-api-platform#readme",
  "bugs": {
    "url": "https://github.com/standonai/human-agent-api-platform/issues"
  },
  "devDependencies": {
    "@stoplight/spectral-cli": "^6.11.0",
    "@stoplight/spectral-rulesets": "^1.17.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.11.5",
    "@types/supertest": "^6.0.3",
    "@types/validator": "^13.15.10",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^4.0.18",
    "drizzle-kit": "^0.31.9",
    "eslint": "^8.57.1",
    "supertest": "^6.3.4",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "minimatch@^3.0.0": "3.1.4",
    "rollup@^2.0.0": "2.80.0",
    "@esbuild-kit/core-utils": {
      "esbuild": "0.25.11"
    }
  }
}
