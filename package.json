{
  "name": "human-agent-api-platform",
  "version": "0.1.0",
  "description": "API platform designed for both human developers and AI agents",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "lint:api": "spectral lint specs/**/*.yaml",
    "test": "vitest",
    "test:targeted": "vitest run src/auth/login-attempt-guard.test.ts src/auth/refresh-token-store.test.ts src/monitoring/startup-posture.test.ts src/middleware/https-enforcement.test.ts",
    "smoke:startup": "bash ./scripts/smoke-startup-validation.sh",
    "preflight:prod-env": "bash ./scripts/preflight-production-env.sh",
    "security:audit": "npm audit --omit=dev --audit-level=high",
    "test:coverage": "vitest --coverage",
    "type-check": "tsc --noEmit",
    "generate:tools": "tsx src/cli/generate-tools.ts",
    "generate:certs": "./scripts/generate-certs.sh",
    "gateway:sync": "tsx src/cli/sync-gateway.ts sync",
    "gateway:status": "tsx src/cli/sync-gateway.ts status",
    "gateway:health": "tsx src/cli/sync-gateway.ts health",
    "db:studio": "drizzle-kit studio"
  },
  "keywords": [
    "api",
    "openapi",
    "ai-agents",
    "llm",
    "developer-experience"
  ],
  "author": "Sumeet Tandon",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/standonai/human-agent-api-platform.git"
  },
  "homepage": "https://github.com/standonai/human-agent-api-platform#readme",
  "bugs": {
    "url": "https://github.com/standonai/human-agent-api-platform/issues"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "express": "^4.18.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.4.1",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.3",
    "prom-client": "^15.1.3",
    "validator": "^13.15.26",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "xss": "^1.0.15",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@stoplight/spectral-cli": "^6.11.0",
    "@stoplight/spectral-rulesets": "^1.17.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.11.5",
    "@types/supertest": "^6.0.3",
    "@types/validator": "^13.15.10",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^4.0.18",
    "drizzle-kit": "^0.31.9",
    "eslint": "^8.57.1",
    "supertest": "^6.3.4",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "optionalDependencies": {
    "@aws-sdk/client-secrets-manager": "^3.700.0",
    "@azure/identity": "^4.5.0",
    "@azure/keyvault-secrets": "^4.9.0",
    "node-vault": "^0.10.2"
  },
  "overrides": {
    "minimatch@^3.0.0": "3.1.4",
    "rollup@^2.0.0": "2.80.0",
    "@esbuild-kit/core-utils": {
      "esbuild": "0.25.11"
    }
  }
}
