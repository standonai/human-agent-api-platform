    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "express": "^4.18.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.4.1",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.3",
    "prom-client": "^15.1.3",
    "validator": "^13.15.26",
