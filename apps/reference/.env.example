# API Platform Environment Configuration

# Database
DATABASE_URL=./data/platform.db   # SQLite file path (default). Change to a different path as needed.
# In production, set DATABASE_URL explicitly to a durable path/volume.
# ALLOW_DEFAULT_SQLITE_IN_PRODUCTION=false

# Server Configuration
NODE_ENV=development
PORT=3000
HTTPS_PORT=443
API_URL=http://localhost:3000
APP_PROFILE=core
# FULL_PROFILE_STRICT=false
# ENABLE_DEMO_ROUTES=false
# ENABLE_BOOTSTRAP_SEEDING=false
# STRICT_STARTUP_VALIDATION=false
# SHUTDOWN_TIMEOUT_MS=10000
# REFRESH_TOKEN_CLEANUP_INTERVAL_MS=3600000
# REFRESH_TOKEN_MAX_ACTIVE_SESSIONS=5
# SERVER_REQUEST_TIMEOUT_MS=30000
# SERVER_HEADERS_TIMEOUT_MS=35000
# SERVER_KEEP_ALIVE_TIMEOUT_MS=5000
# LOGIN_MAX_ATTEMPTS=5
# LOGIN_ATTEMPT_WINDOW_MS=900000
# LOGIN_LOCKOUT_DURATION_MS=900000
# DOCS_BASE_URL=https://docs.your-company.com
# API_MIGRATION_GUIDE_URL=https://docs.your-company.com/migration/2025-01-29
# BOOTSTRAP_ADMIN_EMAIL=admin@example.com
# BOOTSTRAP_ADMIN_PASSWORD=change-me
# BOOTSTRAP_ADMIN_NAME=Admin User
# BOOTSTRAP_AGENT_NAME=test-agent

# ──────────────────────────────────────────────────────────────
# Security Configuration
# ──────────────────────────────────────────────────────────────

# JWT Authentication
# Generate with: openssl rand -base64 32
# ⚠️ CRITICAL: MUST be set in production!
JWT_SECRET=change-me-in-production-use-openssl-rand-base64-32
JWT_EXPIRATION=1h
JWT_REFRESH_EXPIRATION=7d

# CORS - Allowed Origins (comma-separated)
# Development: Defaults to localhost if not set
# Production: MUST be explicitly configured
# Example: https://app.example.com,https://dashboard.example.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ──────────────────────────────────────────────────────────────
# HTTPS (terminated at the reverse proxy — no in-app TLS)
# ──────────────────────────────────────────────────────────────

# TLS certificates live on your reverse proxy (nginx/caddy), not in this
# app. These flags make the app HTTPS-aware behind that proxy:
# ENFORCE_HTTPS=true
# TRUST_PROXY=true
# SECURITY_HSTS_ENABLED=true
# SECURITY_HSTS_MAX_AGE_SECONDS=31536000
# SECURITY_CSP_UPGRADE_INSECURE_REQUESTS=true

# ──────────────────────────────────────────────────────────────
# Secrets Management
# ──────────────────────────────────────────────────────────────

# Built-in provider reads secrets from environment variables.
# For Vault/AWS/Azure, implement the SecretsProvider interface
# (src/secrets/secrets-manager.ts) and wire it in at startup.
# SECRETS_PROVIDER=env

# ──────────────────────────────────────────────────────────────
# Redis Configuration (Distributed Rate Limiting)
# ──────────────────────────────────────────────────────────────

# Redis Connection
# Development: Local Redis (default: localhost:6379)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# Production: Managed Redis (AWS ElastiCache, Azure Cache, etc.)
# REDIS_HOST=your-redis-instance.cache.amazonaws.com
# REDIS_PORT=6379
# REDIS_PASSWORD=your-redis-password
# REDIS_DB=0
# REDIS_TLS=true

# Disable Redis (use in-memory rate limiting)
# DISABLE_REDIS=false

# ──────────────────────────────────────────────────────────────
# Alert Delivery (optional)
# ──────────────────────────────────────────────────────────────

# Slack incoming webhook URL for alert notifications
# SLACK_WEBHOOK_URL=

# PagerDuty Events API v2 routing key
# PAGERDUTY_ROUTING_KEY=

# Generic webhook URL for alert delivery
# ALERT_WEBHOOK_URL=

# OpenAPI Spec Path (Optional)
# OPENAPI_SPEC_PATH=./specs/openapi/platform-api.yaml

# ──────────────────────────────────────────────────────────────
# MCP (Model Context Protocol)
# ──────────────────────────────────────────────────────────────

# Tools are generated from the OpenAPI spec and served at /mcp.
# Restrict the surface to specific spec tags (default: all except
# audit/secrets/monitoring/agents/mcp):
# MCP_TOOL_TAGS=tasks,auth

# Base URL the MCP dispatcher calls back into (default: this server)
# MCP_API_BASE_URL=http://127.0.0.1:3000

# ──────────────────────────────────────────────────────────────
# Delegation (agents acting on behalf of users)
# ──────────────────────────────────────────────────────────────

# Grant lifetime defaults/caps (seconds)
# DELEGATION_DEFAULT_TTL_SECONDS=86400
# DELEGATION_MAX_TTL_SECONDS=604800

# Agent/delegated token lifetime (seconds). Short by design — revocation
# is enforced by live grant checks, not token expiry.
# DELEGATED_TOKEN_TTL_SECONDS=900

# ──────────────────────────────────────────────────────────────
# Human-in-the-loop approvals
# ──────────────────────────────────────────────────────────────

# Pending changes expire if unresolved (seconds)
# APPROVAL_TTL_SECONDS=86400

# Force approval for certain operations:
#   none                  — only explicit ?require_approval=true (default)
#   delegated-destructive — DELETE by a delegated agent always needs approval
# APPROVAL_POLICY=none
