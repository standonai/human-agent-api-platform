{
  "name": "@standonai/agent-metrics",
  "version": "0.1.0",
  "description": "Agent-experience metrics for Express APIs: agent detection, request metrics, and zero-shot success rate tracking",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./agent-types": {
      "types": "./dist/agent-types.d.ts",
      "import": "./dist/agent-types.js"
    },
    "./metrics-store": {
      "types": "./dist/metrics-store.d.ts",
      "import": "./dist/metrics-store.js"
    },
    "./metrics-middleware": {
      "types": "./dist/metrics-middleware.d.ts",
      "import": "./dist/metrics-middleware.js"
    },
    "./agent-tracking": {
      "types": "./dist/agent-tracking.d.ts",
      "import": "./dist/agent-tracking.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "tsc -p tsconfig.json"
  },
  "peerDependencies": {
    "express": "^4.18.0 || ^5.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "typescript": "^5.3.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/standonai/human-agent-api-platform.git",
    "directory": "packages/agent-metrics"
  },
  "keywords": [
    "api",
    "metrics",
    "observability",
    "ai-agents",
    "zero-shot",
    "express"
  ]
}
